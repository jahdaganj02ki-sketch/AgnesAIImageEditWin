<Window x:Class="AgnesAIImageEdit.Views.FullScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" WindowState="Maximized" ResizeMode="NoResize"
        Background="Black" KeyDown="Window_KeyDown">
    <Grid>
        <Border x:Name="Toolbar" VerticalAlignment="Top" Background="#80000000" Padding="10"
                Visibility="Collapsed" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Button Content="&#x2795;" Click="ZoomIn_Click" Style="{StaticResource ToolbarButton}"/>
                <Button Content="&#x2796;" Click="ZoomOut_Click" Style="{StaticResource ToolbarButton}"/>
                <Button Content="&#x27F2;" Click="ResetZoom_Click" Style="{StaticResource ToolbarButton}"/>
                <Button Content="&#x2715;" Click="Close_Click" Style="{StaticResource ToolbarButton}"/>
            </StackPanel>
        </Border>

        <Image x:Name="Image" Source="{Binding ImageSource}" Stretch="Uniform"
               RenderTransformOrigin="0.5,0.5"
               MouseWheel="Image_MouseWheel"
               MouseLeftButtonDown="Image_MouseLeftButtonDown"
               MouseLeftButtonUp="Image_MouseLeftButtonUp"
               MouseMove="Image_MouseMove">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="ScaleTransform"/>
                    <TranslateTransform x:Name="TranslateTransform"/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
    </Grid>
</Window>