<UserControl x:Class="AgnesAIImageEdit.Views.ResultCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:AgnesAIImageEdit.Models"
             xmlns:conv="clr-namespace:AgnesAIImageEdit.Converters">
    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
    </UserControl.Resources>
    <StackPanel>
        <Image Source="{Binding OutputImage}" Stretch="Uniform" MaxHeight="360" Margin="0,0,0,8"/>
        <TextBlock Text="{Binding Prompt}" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock Text="{Binding RevisedPrompt}" TextWrapping="Wrap" Foreground="Gray" FontSize="12" Margin="0,0,0,8"
                   Visibility="{Binding RevisedPrompt, Converter={StaticResource NullToVis}}"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="&#128077;" Width="36" Height="32" Margin="2" Click="Up_Click" ToolTip="Like"/>
            <Button Content="&#128078;" Width="36" Height="32" Margin="2" Click="Down_Click" ToolTip="Dislike"/>
            <Button Content="&#x27F3;" Width="36" Height="32" Margin="2" Click="ContinueEdit_Click" ToolTip="Continue Editing"/>
            <Button Content="&#x26F6;" Width="36" Height="32" Margin="2" Click="FullScreen_Click" ToolTip="Full Screen"/>
            <Button Content="Copy" Width="60" Height="32" Margin="2" Click="Copy_Click"/>
            <Button Content="Share" Width="60" Height="32" Margin="2" Click="Share_Click"/>
            <Button Content="Save" Width="60" Height="32" Margin="2" Click="Save_Click"/>
        </StackPanel>
    </StackPanel>
</UserControl>
