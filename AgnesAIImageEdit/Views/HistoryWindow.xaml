<Window x:Class="AgnesAIImageEdit.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:AgnesAIImageEdit.Models"
        xmlns:conv="clr-namespace:AgnesAIImageEdit.Converters"
        Title="History" Height="520" Width="460" Background="White" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <conv:Base64ToImageConverter x:Key="B64"/>
        <conv:NullToVisibilityConverter x:Key="NullVis"/>
    </Window.Resources>
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" Text="Last 50 generations (double-click to open)" FontWeight="Bold" Margin="0,0,0,8"/>
        <ListBox x:Name="lst" MouseDoubleClick="Lst_DoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:HistoryItem}">
                    <Border Padding="8" BorderBrush="#EEE" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="48" Height="48" Stretch="UniformToFill" Margin="0,0,8,0"
                                   Source="{Binding InputThumbBase64, Converter={StaticResource B64}}"
                                   Visibility="{Binding InputThumbBase64, Converter={StaticResource NullVis}}"/>
                            <StackPanel>
                                <TextBlock Text="{Binding Prompt}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                <TextBlock FontSize="11" Foreground="Gray">
                                    <Run Text="{Binding Mode}"/><Run Text=" • "/><Run Text="{Binding Model}"/><Run Text=" • "/><Run Text="{Binding Timestamp}"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
