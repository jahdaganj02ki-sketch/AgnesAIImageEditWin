<Window x:Class="AgnesAIImageEdit.Views.SettingsWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Settings" Height="600" Width="480" MinWidth="400" MinHeight="540"
	Background="White" WindowStartupLocation="CenterScreen" ResizeMode="CanResize">
	<StackPanel Margin="16">
		<TextBlock Text="Agnes AI Image Edit — Settings" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
		<TextBlock Text="API Base URL" Margin="0,6,0,2"/>
		<TextBox x:Name="txtBaseUrl"/>
		<TextBlock Text="API Key (stored locally, encrypted with DPAPI)" Margin="0,10,0,2"/>
		<PasswordBox x:Name="pwdKey"/>
		<TextBlock Margin="0,2,0,0">
			<Hyperlink Click="GetKey_Click">Get a free API key</Hyperlink>
		</TextBlock>
		<TextBlock Text="Default image model" Margin="0,10,0,2"/>
		<ComboBox x:Name="cmbModel">
			<ComboBoxItem Content="agnes-image-2.1-flash"/>
			<ComboBoxItem Content="agnes-image-2.0-flash"/>
		</ComboBox>
		<CheckBox x:Name="chkEnhance" Content="Enhance prompt with agnes-2.0-flash" Margin="0,10,0,0"/>
		<CheckBox x:Name="chkSoftware" Content="Always use software rendering" Margin="0,6,0,0"/>
		<Grid Margin="0,10,0,0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			<StackPanel Grid.Column="0" Margin="0,0,6,0">
				<TextBlock Text="Output tier (2.1)" Margin="0,0,0,2"/>
				<ComboBox x:Name="cmbTier">
					<ComboBoxItem Content="1K"/><ComboBoxItem Content="2K"/>
					<ComboBoxItem Content="3K"/><ComboBoxItem Content="4K"/>
				</ComboBox>
			</StackPanel>
			<StackPanel Grid.Column="1" Margin="6,0,0,0">
				<TextBlock Text="Ratio (2.1)" Margin="0,0,0,2"/>
				<ComboBox x:Name="cmbRatio">
					<ComboBoxItem Content="1:1"/><ComboBoxItem Content="3:4"/><ComboBoxItem Content="4:3"/>
					<ComboBoxItem Content="16:9"/><ComboBoxItem Content="9:16"/><ComboBoxItem Content="2:3"/>
					<ComboBoxItem Content="3:2"/><ComboBoxItem Content="21:9"/>
				</ComboBox>
			</StackPanel>
		</Grid>
		<TextBlock Text="Output size exact (2.0)" Margin="0,10,0,2"/>
		<ComboBox x:Name="cmbSizeExact">
			<ComboBoxItem Content="1024x1024"/><ComboBoxItem Content="1024x768"/>
			<ComboBoxItem Content="768x1024"/><ComboBoxItem Content="1280x720"/>
		</ComboBox>
		<TextBlock Text="Save folder (blank = app data)" Margin="0,10,0,2"/>
		<DockPanel LastChildFill="True">
			<Button x:Name="btnBrowse" DockPanel.Dock="Right" Content="Browse" Margin="6,0,0,0" Click="Browse_Click"/>
			<TextBox x:Name="txtSaveFolder"/>
		</DockPanel>
		<Button Content="Save" Width="100" HorizontalAlignment="Right" Margin="0,16,0,0" Padding="10,6" Click="Save_Click" Style="{StaticResource PillButton}"/>
	</StackPanel>
</Window>
