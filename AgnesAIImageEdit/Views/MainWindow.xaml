<Window x:Class="AgnesAIImageEdit.Views.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="clr-namespace:AgnesAIImageEdit.Views"
	xmlns:models="clr-namespace:AgnesAIImageEdit.Models"
	xmlns:conv="clr-namespace:AgnesAIImageEdit.Converters"
	Title="Agnes AI Image Edit" Height="720" Width="480" MinWidth="380" MinHeight="560"
	Background="{DynamicResource Brush.WindowBackground}"
	Foreground="{DynamicResource Brush.WindowForeground}"
	WindowStartupLocation="CenterScreen">
	<Window.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVis"/>
		<conv:NullToVisibilityConverter x:Key="NullToVis"/>
	</Window.Resources>

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="220" x:Name="DrawerCol"/>
		</Grid.ColumnDefinitions>

		<Grid Grid.Column="0">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<!-- Title bar -->
			<Border Grid.Row="0" Background="{DynamicResource Brush.Surface}" Padding="10,12"
					BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="0,0,0,1">
				<DockPanel LastChildFill="False">
					<Button Content="&#9776;" Width="36" Height="36" Click="Hamburger_Click"
							Background="Transparent" BorderThickness="0" FontSize="20" Cursor="Hand"
							Foreground="{DynamicResource Brush.TextPrimary}"/>
					<TextBlock Text="Agnes" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0,0,0"
							   Foreground="{DynamicResource Brush.TextPrimary}"/>
				</DockPanel>
			</Border>

			<!-- Messages -->
			<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12"
						  Background="{DynamicResource Brush.WindowBackground}">
				<ItemsControl ItemsSource="{Binding Messages}">
					<ItemsControl.Resources>
						<DataTemplate DataType="{x:Type models:UserPromptItem}">
							<Border Background="{DynamicResource Brush.BubbleUser}" CornerRadius="12" Padding="10" Margin="0,6"
									HorizontalAlignment="Right" MaxWidth="400">
								<StackPanel>
									<Image Source="{Binding PreviewImage}" MaxHeight="160" Margin="0,0,0,6"
										   Visibility="{Binding PreviewImage, Converter={StaticResource NullToVis}}"/>
									<TextBlock Text="{Binding Prompt}" TextWrapping="Wrap"
											   Foreground="{DynamicResource Brush.TextPrimary}"/>
								</StackPanel>
							</Border>
						</DataTemplate>

						<DataTemplate DataType="{x:Type models:StatusItem}">
							<TextBlock Text="{Binding Text}" Foreground="{DynamicResource Brush.TextSecondary}"
									   FontSize="12" Margin="0,4" HorizontalAlignment="Center" TextWrapping="Wrap"/>
						</DataTemplate>

						<DataTemplate DataType="{x:Type models:ResultItem}">
							<Border Background="{DynamicResource Brush.BubbleAssistant}" CornerRadius="12" Padding="10" Margin="0,6"
									BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1">
								<local:ResultCard/>
							</Border>
						</DataTemplate>
					</ItemsControl.Resources>
				</ItemsControl>
			</ScrollViewer>

			<!-- Input area -->
			<Border Grid.Row="2" Background="{DynamicResource Brush.Surface}"
					BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="0,1,0,0" Padding="12">
				<StackPanel>
					<!-- Toolbar: model selector, enhance, toggle, submit -->
					<StackPanel Orientation="Horizontal" Margin="0,0,0,8">
						<ComboBox Width="160" Margin="0,0,8,0" VerticalContentAlignment="Center"
								  ItemsSource="{Binding AvailableModels}"
								  SelectedItem="{Binding SelectedModel}"
								  Background="{DynamicResource Brush.SurfaceInput}"
								  Foreground="{DynamicResource Brush.TextPrimary}"
								  BorderBrush="{DynamicResource Brush.Border}"/>
						<CheckBox Content="Enhance" IsChecked="{Binding Enhance}"
								  VerticalAlignment="Center" Margin="0,0,8,0"
								  Foreground="{DynamicResource Brush.TextPrimary}"/>
						<Button Command="{Binding ToggleModeCommand}" Content="{Binding ModeButtonLabel}"
								Margin="0,0,8,0" Padding="10,4"
								Background="{DynamicResource Brush.SurfaceAlt}"
								Foreground="{DynamicResource Brush.TextPrimary}"
								BorderBrush="{DynamicResource Brush.Border}"/>
						<Button Command="{Binding SubmitCommand}" Content="&#8593;" Width="42" Height="40"
								Style="{StaticResource PillButton}"/>
					</StackPanel>

					<!-- Mode-specific row: image picker -->
					<StackPanel Orientation="Horizontal" Margin="0,0,0,8"
								Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
						<Button Command="{Binding EditImageCommand}" Style="{StaticResource PillButton}" Content="Edit Image"/>
						<Border Visibility="{Binding SelectedImage, Converter={StaticResource NullToVis}}" Margin="10,0,0,0">
							<Grid>
								<Image Source="{Binding SelectedImage}" Width="48" Height="48" Stretch="UniformToFill"/>
								<Button Command="{Binding RemoveImageCommand}" Content="&#10005;"
										Width="18" Height="18" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Top"
										Background="#AA000000" Foreground="White" BorderThickness="0" Cursor="Hand"/>
							</Grid>
						</Border>
					</StackPanel>

					<!-- Prompt input: full width, clearly writable -->
					<TextBox Text="{Binding CurrentPrompt, UpdateSourceTrigger=PropertyChanged}"
							 AcceptsReturn="True" MinHeight="56" VerticalContentAlignment="Center"
							 VerticalScrollBarVisibility="Auto"
							 Background="{DynamicResource Brush.SurfaceInput}"
							 Foreground="{DynamicResource Brush.TextPrimary}"
							 BorderBrush="{DynamicResource Brush.Border}"
							 Padding="8"
							 FontSize="14"/>
				</StackPanel>
			</Border>
		</Grid>

		<!-- Drawer -->
		<Border Grid.Column="1" x:Name="Drawer" Background="{DynamicResource Brush.Drawer}"
				BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1,0,0,0"
				Visibility="Collapsed">
			<StackPanel Margin="12">
				<Button Command="{Binding ToggleModeCommand}" Margin="0,0,0,8" Padding="10,8" Content="{Binding ModeButtonLabel}"/>
				<Button Command="{Binding OpenSettingsCommand}" Margin="0,0,0,8" Padding="10,8" Content="Settings"/>
				<Button Command="{Binding OpenHistoryCommand}" Margin="0,0,0,8" Padding="10,8" Content="History"/>
				<Button Command="{Binding ToggleThemeCommand}" Margin="0,0,0,8" Padding="10,8"
						Content="{Binding ThemeButtonLabel}"/>
				<Separator Margin="0,8"/>
				<TextBlock Text="Agnes AI Image Edit v1.0.0" FontSize="11"
						   Foreground="{DynamicResource Brush.TextSecondary}"/>
				<TextBlock Text="Image editing via Agnes AI API" FontSize="11"
						   Foreground="{DynamicResource Brush.TextSecondary}" TextWrapping="Wrap"/>
			</StackPanel>
		</Border>
	</Grid>
</Window>
